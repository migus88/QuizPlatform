quiz.engine-room.games {
    tls /etc/caddy/certs/quizplatform/origin.pem /etc/caddy/certs/quizplatform/origin-key.pem

    handle /hubs/* {
        reverse_proxy quizplatform-api:5063
    }

    handle /api/* {
        reverse_proxy quizplatform-api:5063
    }

    handle /health {
        reverse_proxy quizplatform-api:5063
    }

    handle {
        reverse_proxy quizplatform-web:3000
    }
}
