# =============================================================================
# Production environment (.env on the VM, in the repo root)
# =============================================================================

# Database
DEPLOY_DB_CONNECTION=Host=postgres;Database=quizplatform;Username=quizplatform;Password=CHANGE_ME
DEPLOY_DB_USER=quizplatform
DEPLOY_DB_PASSWORD=CHANGE_ME
DEPLOY_DB_NAME=quizplatform

# JWT (generate a long random string)
DEPLOY_JWT_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# Frontend (the public URL your site is served at)
NEXT_PUBLIC_API_URL=https://quiz.yourdomain.com

# CORS (must match the public URL)
ALLOWED_ORIGINS=https://quiz.yourdomain.com

# =============================================================================
# Deployment variables (local .env only — not needed on the VM)
# =============================================================================

# AWS Lightsail
DEPLOY_LIGHTSAIL_INSTANCE=quizplatform
DEPLOY_LIGHTSAIL_REGION=eu-central-1
DEPLOY_LIGHTSAIL_SNAPSHOT=quizplatform-snap
DEPLOY_LIGHTSAIL_STATIC_IP=quizplatform-ip
DEPLOY_LIGHTSAIL_BUNDLE=micro_3_0

# SSH
DEPLOY_SSH_USER=ubuntu
DEPLOY_SSH_KEY=~/.ssh/quizplatform.pem

# Health check
DEPLOY_API_URL=https://quiz.yourdomain.com
