# Replace quiz.yourdomain.com with your actual domain
quiz.yourdomain.com {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin-key.pem

    handle /hubs/* {
        reverse_proxy api:5063
    }

    handle /api/* {
        reverse_proxy api:5063
    }

    handle /health {
        reverse_proxy api:5063
    }

    handle {
        reverse_proxy web:3000
    }
}
